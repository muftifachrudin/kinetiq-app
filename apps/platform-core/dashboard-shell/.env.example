# Same Clerk project api-gateway verifies JWTs against (CLERK_JWKS_URL there
# must match this project). Get both from the Clerk Dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Base URL of the api-gateway service this dashboard calls (/me,
# /trading/signals). Local dev: http://localhost:8000. Production: the
# Railway api-gateway public URL.
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8000
