# Copy to .env for local dev only. NEVER commit the real .env (already gitignored).
# In Railway, set these as service environment variables instead of using this file.

# --- Neon ---
DATABASE_URL=                    # postgres connection string for the target Neon branch
NEON_API_KEY=                    # Neon Console -> Account Settings -> API Keys (used by CI/CLI to create/delete branches)
NEON_PROJECT_ID=                 # Neon Console -> Project Settings

# --- Railway ---
RAILWAY_TOKEN=                   # Railway Dashboard -> Project -> Settings -> Tokens (Project Token, scoped, preferred over Account Token)

# --- LLM ---
OPENROUTER_API_KEY=              # dedicated key for the Kinetiq project

# --- Market data ---
COINGLASS_API_KEY=               # Hobbyist tier

# --- Billing (dual-provider Midtrans + XIDR/IDRX — see docs/prd.md B.16) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
XIDR_API_KEY=                    # StraitsX Indonesia Business Account (Sole Trader), primary stablecoin provider
IDRX_API_KEY=                    # backup stablecoin provider, docs.idrx.co

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=              # Clerk Dashboard -> API Keys -> "JWKS URL" (or https://<frontend-api>/.well-known/jwks.json)

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- KMS (envelope encryption master key for tenant_credential) ---
KMS_MASTER_KEY_ID=
